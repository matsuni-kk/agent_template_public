---
description: ルール保守（追加・編集）システム（汎用）
globs:
---
# ==========================================================
# 99_rule_maintenance.mdc - ルール保守システム（汎用）
# ==========================================================

path_reference: "agent_paths.mdc"

# ======== プロンプト（目的と使い方） ========
prompt_purpose: |
  任意ドメインのエージェントで、ルール（00/01〜89/90/97/98/99）を安全かつ一貫フォーマットで追加・編集し、適用後すぐ実運用できる状態に整えます。

prompt_why_questions: |
  番号重複・命名不整合・必須セクション欠落・パス不一致を防ぐため、操作種別・番号(NN)・機能名/コード・トリガー・出力先・理由・レビュー情報を事前確定します。

prompt_why_templates: |
  完全スケルトンと変更ログテンプレートを提供し、成果物の品質・可監査性・再利用性を担保します。

prompt_principles: |
  - 命名は `NN_{{meta.domain}}_{function}.mdc`（NNは2桁）で統一する。
  - path_reference は常に `{domain}_paths.mdc`（本テンプレでは `agent_paths.mdc`）。
  - プロンプト4点・Phase1/2・プロセス・質問・テンプレ・設定/統合/品質/成功メトリクスを必須とする。
  - 追加・編集はログ化し、レビュー・承認を確実に通過させる。

# ======== ルール保守統合エージェント ========

system_capabilities:
  rule_scaffolding: "NN/命名/見出し/必須セクションを満たす汎用スケルトン生成"
  format_enforcement: "標準フォーマットの自動検証（プロンプト4点等）"
  trigger_registration: "マスターへのトリガー追記指針を提示"
  path_integration: "pathsファイルとの整合点検と追加提案"
  qa_checklist: "レビュー観点のチェックリスト生成"
  audit_logging: "変更ログ（誰/いつ/なぜ/何を）を作成"

# ======== Phase 1: 計画フェーズ ========

phase_1_description: |
  目的・対象・影響範囲を明確にし、番号競合と命名規則適合を確認します。必要なら paths に新パターンを追加します。完了条件は入力要件充足です。

# ======== Phase 2: 適用フェーズ ========

phase_2_description: |
  add はスケルトン生成、edit は変更差分チェックとパッチ提案を行います。必要に応じてマスターの master_triggers に追記します。完了条件はログ作成とレビュー準備です。

# ======== 統合オプション質問 ========

rule_maintenance_questions:
  - key: "operation"
    prompt: "操作種別（add|edit）："
    type: "text"
    required: true
    placeholder: "add"
  - key: "nn"
    prompt: "対象番号（NN 2桁。01〜89: ドメイン機能、90/97/98/99: 管理）："
    type: "text"
    required: true
    placeholder: "16"
  - key: "function_code"
    prompt: "機能コード（英小文字+_。例: change_request）："
    type: "text"
    required: true
    placeholder: "rule_guidelines"
  - key: "function_name"
    prompt: "機能名（日本語）。例：ルール作成ガイド："
    type: "text"
    required: true
    placeholder: "ルール作成ガイド"
  - key: "trigger_pattern"
    prompt: "マスタートリガーの正規表現（()で包括、|区切り）："
    type: "multiline"
    required: false
    placeholder: "(ルール作成|ルール保守|rule maintenance)"
  - key: "document_type"
    prompt: "主たるドキュメントタイプ（ドラフト/ログ等）："
    type: "text"
    required: false
    placeholder: "rule maintenance log"
  - key: "add_master_trigger"
    prompt: "00_master_rules.mdc にトリガー追記しますか？（yes|no）："
    type: "text"
    required: false
    placeholder: "yes"
  - key: "new_patterns"
    prompt: "paths に新規追加したいパターン（任意。key: value...）："
    type: "multiline"
    required: false
    placeholder: "draft_some_output: '{{dirs.flow}}/Public/{{meta.today}}/some.md'"
  - key: "reason"
    prompt: "変更理由（Why）と期待効果："
    type: "multiline"
    required: true
  - key: "reviewer"
    prompt: "レビュー責任者（氏名/ロール）："
    type: "text"
    required: true
  - key: "due"
    prompt: "レビュー期限（YYYY-MM-DD）："
    type: "text"
    required: true

# ======== ルール保守プロセス ========

rule_maintenance_steps:
  1_scaffold_or_edit:
    name: "スケルトン生成/編集準備"
    phases:
      - "operation=add: 汎用スケルトン生成（NN/命名/区切り/必須セクション）"
      - "operation=edit: 既存ファイルの必須セクション/命名/区切りの点検"
      - "paths 整合確認（不足時は new_patterns 提案）"
    quality_standards:
      - "プロンプト4点・system_capabilities・Phase1/2・プロセス・質問・テンプレ・設定・統合・品質・成功メトリクスが存在"
      - "path_reference が {domain}_paths.mdc に対応（本テンプレは agent_paths）"
      - "alwaysApply の規約準拠"

  2_register_and_log:
    name: "トリガー登録とログ作成"
    phases:
      - "必要に応じ 00_master_rules.mdc にトリガー追記（完全形式）"
      - "変更ログ（誰/いつ/なぜ/何を/どこへ）を作成"
      - "レビュー観点（形式/整合/安全/運用）チェックリスト化"
    integration_points:
      - "00_master_rules.mdc => master_triggers"
      - "agent_paths.mdc"
      - "Flow/Public（ログ配置）"

# ======== ルール保守ワークフロー ========

rule_maintenance_workflow:
  phase_1:
    - name: "変更ログ作成"
      action: "create_markdown_file"
      description: "ルール保守の変更ログを作成"
      mandatory: true

# ======== テンプレート ========

rule_skeleton_template: |
  ---
  description: {{meta.domain}} における {{function_name}} システム
  globs:
    alwaysApply: false
  ---
  # ==========================================================
  # {{nn}}_{{meta.domain}}_{{function_code}}.mdc - {{function_name}}システム
  # ==========================================================

  path_reference: "{{meta.domain}}_paths.mdc"

  # ======== プロンプト（目的と使い方） ========
  prompt_purpose: |
    本ルールは {{function_name}} の事実を整え、合意形成と次アクションを高速化します。出来事記録の標準を守り、再現可能性を高めます。

  prompt_why_questions: |
    欠落・曖昧・書式ブレを防ぐため、5W1HとType別DoD、詳細度（L1/L2/L3）を満たす質問を用意します。

  prompt_why_templates: |
    一貫したテンプレで列・見出し・用語を統一し、監査と自動化を容易にします。

  prompt_principles: |
    - 追記専用で記録し、過去行は不変とする。
    - 事実のみ記述し、Whyは当時の明言に限定する。
    - 出典必須、24時間以内に追記、Thread鎖を維持する。

  # ======== {{function_name}}システム統合エージェント ========

  system_capabilities:
    core_function: "{{function_name}}に関する中核処理"
    data_processing: "データ整形・検証・変換"
    workflow_management: "ワークフロー制御と自動化"
    quality_assurance: "必須項目検証とDoD確認"
    integration_support: "paths/他ルール連携"
    user_experience: "最小手順で正確に記録"

  # ======== Phase 1: 定義フェーズ ========

  phase_1_description: |
    目的・範囲・品質基準を合意し、入力要件を確認します。完成条件を明確にします。

  # ======== Phase 2: 作成フェーズ ========

  phase_2_description: |
    入力に基づきテンプレートを適用し、出力を生成します。最小の手戻りで確定させます。

  # ======== 統合オプション質問 ========

  {{function_code}}_questions:
    - key: "example_key"
      prompt: "例：必要情報を入力してください："
      type: "text"
      required: false

  # ======== {{function_name}}プロセス ========

  {{function_code}}_steps:
    1_prepare:
      name: "準備"
      phases:
        - "要件確認"
        - "出力定義"
        - "レビュー調整"
      quality_standards:
        - "必須入力が揃っている"
        - "pathsとの整合を確認"
        - "承認者が設定済み"

  # ======== {{function_name}}ワークフロー ========

  {{function_code}}_workflow:
    phase_1:
      - name: "ドラフト生成"
        action: "create_markdown_file"
        description: "Flowにドラフト作成"
        mandatory: true

  # ======== テンプレート ========

  {{function_code}}_template: |
    # {{function_name}} - {{meta.timestamp}}

    ## サマリー
    {{example_key}}

  # ======== エラーハンドリング ========

  error_handling:
    generic_error:
      message: "エラーが発生しました。入力内容とpaths設定を確認してください。"
      recovery_actions:
        - "入力値を再確認"
        - "pathsのキーを更新"

  # ======== 設定 ========

  {{function_code}}_settings:
    sample_setting: "value"

  # ======== 統合ポイント ========

  integration_points:
    sample_system:
      trigger: "更新時"
      action: "通知する"

  # ======== 品質保証 ========

  quality_assurance:
    mandatory_checks:
      - "必須入力が埋まっている"
      - "命名規則が遵守されている"

  # ======== 成功メトリクス ========

  success_metrics:
    - "レビュー差戻し率 < 10%"
    - "適用後の修正回数 < 1回/ルール"

# ======== エラーハンドリング ========

error_handling:
  invalid_nn:
    message: "NNが規定外です。01〜99の2桁で指定してください。"
    recovery_actions:
      - "番号リストを確認"
      - "既存ルールと重複がないか照合"
  missing_reason:
    message: "変更理由が入力されていません。Whyを必ず記録してください。"
    recovery_actions:
      - "reasonフィールドを追記"
      - "背景情報を添付"

# ======== 設定 ========

rule_maintenance_settings:
  log_path: "{{patterns.flow_public_logs}}"
  default_reviewer: "チームリード"
  approval_required: true

# ======== 統合ポイント ========

integration_points:
  master_rules:
    trigger: "トリガー追加"
    action: "master_triggers を更新"
  paths_file:
    trigger: "新規パターン登録"
    action: "agent_paths.mdc を編集"

# ======== 品質保証 ========

quality_assurance:
  mandatory_checks:
    - "必須項目が入力済み"
    - "変更ログがFlow/Publicに保存済み"
    - "レビュー期限が設定"

# ======== 成功メトリクス ========

success_metrics:
  - "レビュー差戻し率 < 5%"
  - "ルール更新から配布までの時間 < 1営業日"
  - "フォーマット逸脱ゼロを3連続更新で達成"
