        - "ルール番号体系準拠"
        - "ファイル構造準拠"
        - "{{patterns.xxx}} 形式の正確な使用"
      flow_stock:
        - "Flow → Stock の文書管理フローを考慮"
        - "Public/Private ディレクトリの適切な使い分け"
        - "Archived による履歴管理"
      numbering:
        - "00: Master Control Rules"
        - "01〜89: Domain Specialized Rules"
        - "97: Flow to Stock Rules"
        - "98: Flow Assist"
        - "99: Rule Maintenance"
  implementation_priorities:
    phase1:
      summary: "必須基盤機能 (1-3ルール)"
      steps:
        - "01_core_functions: 基幹機能群"
        - "02_primary_workflow: 主要業務機能群"
        - "03_management_support: 管理支援機能群"
    phase2:
      summary: "中核業務機能 (4-8ルール)"
      details:
        - "ドメイン主要ワークフローを網羅"
        - "業界標準の必須プロセスをカバー"
    phase3:
      summary: "完成・評価機能 (9-15ルール)"
      details:
        - "分析・評価機能群"
        - "最終レポート・文書作成機能群"
        - "品質管理・完了確認機能群"
    strategy:
      - "Taskリスト完了後に実装を開始する。"
      - "まず3ルールでMVPを構築する。"
      - "段階的に15ルール以内でドメイン全体をカバーする。"
      - "各ルールは関連機能をまとめて実用レベルまで詳細化する。"
      - "フェーズ3完了後に品質評価とブラッシュアップを必ず実施する。"
    design_flexibility:
      first_rule_patterns:
        - "パターンA（プロジェクト型）: 初期化 + 基本設定 + 構造作成"
        - "パターンB（単機能型）: 最重要単機能"
        - "パターンC（複合型）: 関連2-3機能の複合"
      combination_principles:
        - "機能的関連性でまとめる。"
        - "利用頻度の高い機能をセットにする。"
        - "アウトプット連携のある機能をまとめる。"
        - "同一トリガー・質問・テンプレートを共有できる機能をまとめる。"


# =========================
# エージェント品質評価・ブラッシュアップフレームワーク
# =========================

agent_quality_framework:
  evaluation_steps:
    step6:
      title: "エージェント品質評価"
      dimensions:
        syntax_compliance:
          description: "記述規則準拠性"
          criteria:
            - "YAML構文が正確か"
            - "ルール番号体系 (00-99) に従っているか"
            - ".cursor/rules/ 構造と命名規則に準拠しているか"
            - "{{patterns.xxx}} 形式のパス参照が正確か"
          checklist: |-
            syntax_compliance:
              - yaml_syntax_accuracy: [1-5点]
              - rule_numbering_compliance: [1-5点]
              - file_structure_compliance: [1-5点]
              - path_pattern_compliance: [1-5点]

            # 4項目平均4.0以上で合格
        functional_completeness:
          description: "機能充足性"
          criteria:
            - "業界標準フレームワークへの整合性"
            - "主要ワークフローの網羅度"
            - "機能間の連携性"
            - "実務適用性"
          checklist: |-
            functional_completeness:
              - standard_framework_alignment: [1-5点]
              - workflow_completeness: [1-5点]
              - function_integration: [1-5点]
              - practical_usability: [1-5点]

            # 4項目平均4.0以上で合格
        goal_alignment:
          description: "ゴール適合性"
          criteria:
            - "初期要件との整合"
            - "ターゲットユーザー適合"
            - "業務効率化効果"
            - "学習曲線"
          checklist: |-
            goal_alignment:
              - initial_requirement_match: [1-5点]
              - target_user_fit: [1-5点]
              - efficiency_improvement: [1-5点]
              - learning_curve: [1-5点]

            # 4項目平均4.0以上で合格
        practical_utility:
          description: "実用性"
          criteria:
            - "質問品質"
            - "テンプレート品質"
            - "エラーハンドリング"
            - "拡張性"
          checklist: |-
            practical_utility:
              - question_quality: [1-5点]
              - template_quality: [1-5点]
              - error_handling: [1-5点]
              - extensibility: [1-5点]

            # 4項目平均4.0以上で合格
    step7:
      title: "厳格な品質評価とドキュメント化"
      process:
        - "evaluation_report_YYYY-MM-DD.md を作成する。"
        - "各評価項目を1-5点で採点し、3.5点未満は要改善とする。"
        - "改善内容を具体的にフィードバックへ記載する。"
        - "フィードバックに基づきブラッシュアップ要否を判定する。"
      report_template: |-
        # エージェント品質評価報告書

        **評価対象**: {AgentName}エージェント
        **評価日**: {{env.NOW:date:YYYY-MM-DD}}
        **評価者**: [評価者名]

        ## 1. 記述規則準拠性評価

        ### 1.1 YAML構文正確性 [X.X/5.0]
        **評価基準**: トリガー・ステップ・アクションのYAML記法が正確か
        **評価結果**: X.X点
        **詳細フィードバック**:
        - ✅ 良い点: [正確なYAML記述箇所]
        - ❌ 問題点: [構文エラー・不正な記述]
        - 🔧 改善指示: [具体的な修正方法・正しい記述例]

        ### 1.2 ルール番号体系準拠 [X.X/5.0]
        **評価基準**: 00-99の番号体系に従った適切なファイル配置
        **評価結果**: X.X点
        **詳細フィードバック**:
        - ✅ 良い点: [適切なファイル番号・配置]
        - ❌ 問題点: [番号体系違反・不適切な配置]
        - 🔧 改善指示: [正しいファイル番号・配置方法]

        ### 1.3 ファイル構造準拠 [X.X/5.0]
        **評価基準**: .cursor/rules/構造とファイル命名規則への準拠
        **評価結果**: X.X点
        **詳細フィードバック**:
        - ✅ 良い点: [適切なファイル構造・命名]
        - ❌ 問題点: [構造違反・命名規則違反]
        - 🔧 改善指示: [正しいファイル構造・命名方法]

        ### 1.4 パスパターン準拠 [X.X/5.0]
        **評価基準**: {{patterns.xxx}}形式の正確な使用とパス参照の整合性
        **評価結果**: X.X点
        **詳細フィードバック**:
        - ✅ 良い点: [正確なパスパターン使用]
        - ❌ 問題点: [パスパターンエラー・参照不整合]
        - 🔧 改善指示: [正しいパスパターン記述方法]

        **記述規則準拠性総合評価**: [平均点]/5.0

        ## 2. 機能充足性評価

        ### 2.1 業界標準準拠度 [X.X/5.0]
        **評価基準**: 対象ドメインの確立されたフレームワークとの整合性
        **評価結果**: X.X点
        **詳細フィードバック**:
        - ✅ 良い点: [具体的な良い点]
        - ❌ 問題点: [具体的な問題点]
        - 🔧 改善指示: [具体的な改善方法]

        ### 2.2 ワークフロー網羅度 [X.X/5.0]
        **評価基準**: ドメインの主要業務プロセスが適切にカバーされているか
        **評価結果**: X.X点
        **詳細フィードバック**:
        - ✅ 良い点: [カバーされている業務プロセス]
        - ❌ 問題点: [不足している業務プロセス]
        - 🔧 改善指示: [追加すべき機能・修正すべき点]

        ### 2.3 機能間連携 [X.X/5.0]
        **評価基準**: 各機能が相互に連携し、一貫したワークフローを形成しているか
        **評価結果**: X.X点
        **詳細フィードバック**:
        - ✅ 良い点: [連携が良好な機能群]
        - ❌ 問題点: [連携不備・矛盾点]
        - 🔧 改善指示: [連携改善方法]

        ### 2.4 実務適用性 [X.X/5.0]
        **評価基準**: 実際の業務シーンで即座に使用可能な質問・テンプレートか
        **評価結果**: X.X点
        **詳細フィードバック**:
        - ✅ 良い点: [実用的な質問・テンプレート]
        - ❌ 問題点: [不十分・不適切な質問・テンプレート]
        - 🔧 改善指示: [具体的な修正方法]

        **機能充足性総合評価**: [平均点]/5.0

        ## 3. ゴール適合性評価

        ### 3.1 初期要件適合 [X.X/5.0]
        ### 3.2 ターゲットユーザー適合 [X.X/5.0]
        ### 3.3 業務効率化効果 [X.X/5.0]
        ### 3.4 学習曲線 [X.X/5.0]

        **ゴール適合性総合評価**: [平均点]/5.0

        ## 4. 実用性評価

        ### 4.1 質問品質 [X.X/5.0]
        ### 4.2 テンプレート品質 [X.X/5.0]
        ### 4.3 エラーハンドリング [X.X/5.0]
        ### 4.4 拡張性 [X.X/5.0]

        **実用性総合評価**: [平均点]/5.0

        ## 5. 総合評価

        **全体総合点**: [4観点の平均]/5.0
        ### 合格/不合格判定
        - [ ] 合格（全観点4.0以上）
        - [ ] 条件付き合格（全観点3.5以上、一部改善必要）
        - [ ] 不合格（いずれかの観点3.5未満）

        ### 致命的問題（即座に修正必要）
        1. [致命的問題1]
        2. [致命的問題2]

        ### 重要問題（優先的に修正推奨）
        1. [重要問題1]
        2. [重要問題2]

        ### 改善提案（品質向上のため）
        1. [改善提案1]
        2. [改善提案2]

        ## 5. ブラッシュアップ要否判定

        ### 判定結果
        - [ ] 必須ブラッシュアップ（不合格のため）
        - [ ] 推奨ブラッシュアップ（品質向上のため）
        - [ ] ブラッシュアップ不要（合格基準達成）

        ### ブラッシュアップ計画（該当する場合）
        **優先順位1（致命的問題）**:
        - 問題: [具体的問題]
        - 対策: [具体的対策]
        - 工数見積: [X日]
        - 担当: [担当者]

        **優先順位2（重要問題）**:
        - 問題: [具体的問題]
        - 対策: [具体的対策]
        - 工数見積: [X日]
        - 担当: [担当者]

        ### 次回評価予定
        **予定日**: [YYYY-MM-DD]
        **評価重点**: [重点的に確認する項目]
    step8:
      title: "戦略的ブラッシュアップ実施"
      decision_flow: |-
        brushup_decision_flow:
          step1: "評価MDファイル詳細レビュー"
          step2: "問題の優先度・影響度分析"
          step3: "改善コスト・効果分析"
          step4: "ブラッシュアップ要否の戦略判断"
          step5: "実施判定なら詳細計画策定"
          step6: "ブラッシュアップ実行"
          step7: "再評価・完了判定"
      criteria:
        mandatory:
          - "いずれかの観点が3.5未満"
          - "致命的問題が1つでも存在"
          - "業界標準に明確に反する内容"
        recommended:
          - "全観点3.5以上だが4.0未満"
          - "重要問題が複数存在"
          - "競合優位性向上の余地がある"
        optional:
          - "全観点4.0以上"
          - "致命的・重要問題なし"
          - "追加改善のROIが低い"
      action_levels:
        level1:
          description: "軽微修正 (1-2日)"
          actions:
            - "文言調整・表記統一"
            - "軽微なテンプレート修正"
            - "トリガー語彙の追加"
        level2:
          description: "機能改善 (3-5日)"
          actions:
            - "質問項目の再構成"
            - "テンプレート構造の見直し"
            - "パスパターンの最適化"
        level3:
          description: "構造変更 (1-2週間)"
          actions:
            - "機能統合・分離・再設計"
            - "ワークフロー全体見直し"
            - "新機能追加・不要機能削除"
        level4:
          description: "根本的見直し (2-4週間)"
          actions:
            - "ドメイン分析のやり直し"
            - "アーキテクチャの抜本的変更"
            - "エージェント全体の再設計"
      completion_criteria:
        - "全4観点4.0以上"
        - "記述規則準拠性4.0以上"
        - "致命的問題ゼロ"
        - "重要問題最大1件まで"
        - "実務で即利用可能な品質を確認"
      benefits:
        - "実用性の保証"
        - "継続的改善サイクルの確立"
        - "リリース品質の標準化"
        - "ROI最大化"


# =========================
# 注意事項
# =========================

important_notes:
  - "業界標準フレームワークに必ず基づく。"
  - "機械的生成ではなく手作り品質を維持する。"
  - "生成後の手動修正は必須（自動生成は骨格のみ）。"
  - "品質評価とブラッシュアップは必須プロセスである。"
  - "実務経験者による検証を推奨する。"


# important-instruction-reminders
Do what has been asked; nothing more, nothing less.
NEVER create files unless they're absolutely necessary for achieving your goal.
ALWAYS prefer editing an existing file to creating a new one.
NEVER proactively create documentation files (*.md) or README files. Only create documentation files if explicitly requested by the User.
