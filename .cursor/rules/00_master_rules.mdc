            deliverable: "質問設計書とテンプレ仕様書"
          - task: "トリガー・アクション設計"
            content: "00_master_rules.mdc のトリガー設計"
            deliverable: "トリガー・アクション仕様書"
    compliance_checklist:
      syntax:
